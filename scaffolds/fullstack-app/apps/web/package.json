{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 2026",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "size-limit": "size-limit"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/**/*.js",
      "limit": "350 KB"
    }
  ],
  "dependencies": {
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "@sentry/nextjs": "^8.51.0",
    "@hookform/resolvers": "^3.10.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^2.0.7",
    "zod": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@repo/config": "workspace:*",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.0.0",
    "msw": "^2.7.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
